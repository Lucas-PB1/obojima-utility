rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isSelf(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function canAccessUser(userId) {
      return isSelf(userId) || isAdmin();
    }

    function isParticipant(participants) {
      return signedIn() && request.auth.uid in participants;
    }

    match /users/{userId} {
      allow read: if canAccessUser(userId);
      allow create: if isSelf(userId) &&
        (!('role' in request.resource.data) || request.resource.data.role == 'user');
      allow update: if isAdmin() ||
        (isSelf(userId) && request.resource.data.role == resource.data.role);
      allow delete: if isAdmin();

      match /collectedIngredients/{ingredientId} {
        allow read, write: if canAccessUser(userId);
      }

      match /forageAttempts/{attemptId} {
        allow read, write: if canAccessUser(userId);
      }

      match /recipes/{recipeId} {
        allow read, write: if canAccessUser(userId);
      }

      match /createdPotions/{potionId} {
        allow read, write: if canAccessUser(userId);
      }
    }

    match /public_users/{userId} {
      allow read: if signedIn();
      allow create, update: if isAdmin() ||
        (isSelf(userId) && request.resource.data.uid == userId);
      allow delete: if isAdmin();
    }

    match /friends/{friendshipId} {
      allow read: if isParticipant(resource.data.participants);
      allow create: if isParticipant(request.resource.data.participants);
      allow update, delete: if isParticipant(resource.data.participants);
    }

    match /friendRequests/{requestId} {
      allow read: if signedIn() && (
        request.auth.uid == resource.data.fromUserId ||
        request.auth.uid == resource.data.toUserId
      );
      allow create: if signedIn() && request.auth.uid == request.resource.data.fromUserId;
      allow update: if signedIn() && (
        request.auth.uid == resource.data.fromUserId ||
        request.auth.uid == resource.data.toUserId
      );
      allow delete: if isAdmin();
    }

    match /chats/{chatId} {
      allow read, update, delete: if isParticipant(resource.data.participants);
      allow create: if isParticipant(request.resource.data.participants);

      match /messages/{messageId} {
        allow read: if isParticipant(
          get(/databases/$(database)/documents/chats/$(chatId)).data.participants
        );
        allow create: if isParticipant(
          get(/databases/$(database)/documents/chats/$(chatId)).data.participants
        ) && request.resource.data.senderId == request.auth.uid;
        allow update, delete: if isParticipant(
          get(/databases/$(database)/documents/chats/$(chatId)).data.participants
        );
      }
    }

    match /trades/{tradeId} {
      allow read: if isParticipant(resource.data.participants);
      allow create: if signedIn() &&
        request.auth.uid == request.resource.data.fromUserId &&
        isParticipant(request.resource.data.participants);
      allow update, delete: if isAdmin();
    }
  }
}
