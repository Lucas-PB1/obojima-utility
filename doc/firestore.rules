rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function userDoc(uid) {
      return get(/databases/$(database)/documents/users/$(uid));
    }

    function isAdmin() {
      return signedIn() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        userDoc(request.auth.uid).data.role == 'admin';
    }

    function isSelf(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function canAccessUser(userId) {
      return isSelf(userId) || isAdmin();
    }

    function isParticipant(participants) {
      return signedIn() && request.auth.uid in participants;
    }

    function isTwoParty(participants) {
      return participants is list &&
        participants.size() == 2 &&
        participants[0] is string &&
        participants[1] is string &&
        participants[0] != participants[1];
    }

    function participantDocId(documentId, participants) {
      return isTwoParty(participants) &&
        isParticipant(participants) &&
        (
          documentId == participants[0] + '_' + participants[1] ||
          documentId == participants[1] + '_' + participants[0]
        );
    }

    function activeFriendship(documentId) {
      return exists(/databases/$(database)/documents/friends/$(documentId));
    }

    function selfUserCreateFields() {
      return [
        'uid',
        'email',
        'displayName',
        'photoURL',
        'role',
        'createdAt',
        'lastLogin',
        'updatedAt',
        'settings'
      ];
    }

    function selfUserUpdateFields() {
      return [
        'email',
        'displayName',
        'photoURL',
        'lastLogin',
        'updatedAt',
        'settings'
      ];
    }

    function validSelfUserCreate(userId) {
      return isSelf(userId) &&
        request.resource.data.keys().hasOnly(selfUserCreateFields()) &&
        request.resource.data.uid == userId &&
        request.resource.data.role == 'user';
    }

    function validSelfUserUpdate() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(selfUserUpdateFields()) &&
        request.resource.data.uid == resource.data.uid &&
        request.resource.data.role == resource.data.role;
    }

    function publicProfileFields() {
      return [
        'uid',
        'displayName',
        'searchName',
        'photoURL',
        'lastSeen',
        'createdAt',
        'updatedAt'
      ];
    }

    function validPublicProfile(userId) {
      return isSelf(userId) &&
        request.resource.data.keys().hasOnly(publicProfileFields()) &&
        request.resource.data.uid == userId &&
        request.resource.data.displayName is string &&
        request.resource.data.searchName is string &&
        request.resource.data.lastSeen is timestamp &&
        request.resource.data.updatedAt is timestamp;
    }

    function canReadFriendRequest() {
      return signedIn() && (
        request.auth.uid == resource.data.fromUserId ||
        request.auth.uid == resource.data.toUserId
      );
    }

    function canReadBlock() {
      return signedIn() && (
        request.auth.uid == resource.data.blockerId ||
        request.auth.uid == resource.data.blockedUserId ||
        isAdmin()
      );
    }

    function canReadReport() {
      return signedIn() && (
        request.auth.uid == resource.data.reporterId ||
        isAdmin()
      );
    }

    function canUpdateNotification() {
      return signedIn() &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']) &&
        request.resource.data.read == true;
    }

    match /users/{userId} {
      allow read: if canAccessUser(userId);
      allow create: if validSelfUserCreate(userId) || isAdmin();
      allow update: if (isSelf(userId) && validSelfUserUpdate()) || isAdmin();
      allow delete: if isAdmin();

      match /collectedIngredients/{ingredientId} {
        allow read, write: if canAccessUser(userId);
      }

      match /forageAttempts/{attemptId} {
        allow read, write: if canAccessUser(userId);
      }

      match /recipes/{recipeId} {
        allow read, write: if canAccessUser(userId);
      }

      match /createdPotions/{potionId} {
        allow read, write: if canAccessUser(userId);
      }

      match /notifications/{notificationId} {
        allow read: if canAccessUser(userId);
        allow create, delete: if isAdmin();
        allow update: if (isSelf(userId) && canUpdateNotification()) || isAdmin();
      }

      match /fcmTokens/{tokenId} {
        allow read: if canAccessUser(userId);
        allow create, update, delete: if isAdmin();
      }

      match /{document=**} {
        allow read, write: if false;
      }
    }

    match /public_users/{userId} {
      allow read: if signedIn();
      allow create: if validPublicProfile(userId) || isAdmin();
      allow update: if (
        validPublicProfile(userId) &&
        request.resource.data.uid == resource.data.uid
      ) || isAdmin();
      allow delete: if isAdmin();
    }

    match /friends/{friendshipId} {
      allow read: if isParticipant(resource.data.participants);
      allow create, update, delete: if isAdmin();
    }

    match /friendRequests/{requestId} {
      allow read: if canReadFriendRequest();
      allow create, update, delete: if isAdmin();
    }

    match /chats/{chatId} {
      allow read: if isParticipant(resource.data.participants);
      allow create, update: if isAdmin();
      allow delete: if isAdmin();

      match /messages/{messageId} {
        // Usa senderId/receiverId no documento (evita get() no chat e falhas em queries).
        allow read: if signedIn() && (
          request.auth.uid == resource.data.senderId ||
          request.auth.uid == resource.data.receiverId
        );
        allow create, update, delete: if isAdmin();
      }
    }

    match /trades/{tradeId} {
      allow read: if isParticipant(resource.data.participants) || isAdmin();
      allow create, update, delete: if isAdmin();
    }

    match /blocks/{blockId} {
      allow read: if canReadBlock();
      allow create, update, delete: if isAdmin();
    }

    match /reports/{reportId} {
      allow read: if canReadReport();
      allow create, update, delete: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
